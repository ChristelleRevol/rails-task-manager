<h1 class="mb-3">Tasks</h1>

<% @tasks.each do |task| %>
<div class="my-2">
    <input type="checkbox" name=<% task.title %> <% task.completed ? "checked" : "" %> />
    <%= link_to task.title, task_path(task), class: "text-decoration-none" %>
    <%= link_to '', task_path(task),
  data: {turbo_method: :delete, turbo_confirm: "Are you sure?"}, class: "text-decoration-none fa-solid fa-trash" %>
  </div>
<% end %>

<%= link_to 'New task', new_task_path, class: "text-decoration-none" %>
