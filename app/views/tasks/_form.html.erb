<%= form_with model: task do |f| %>
<div class="mb-3">
  <%= f.label :title, class: "form-label" %>
  <%= f.text_field :title, class: "form-control" %>
  <%= f.label :details, class: "form-label" %>
  <%= f.text_field :details, class: "form-control" %>
  <%= f.submit class: "btn btn-primary mt-2" %>
</div>
<%  end %>
