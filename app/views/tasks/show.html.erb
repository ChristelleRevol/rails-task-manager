<h1 class="mb-3"> <%= @task.title %> </h1>

<p class="bg-secondary bg-opacity-25 border p-3 mb-3"> <%= @task.details %> </p>

<div class="d-flex flex-column mb-3">
<%= link_to '', task_path(@task),
  data: {turbo_method: :delete, turbo_confirm: "Are you sure?"}, class: "text-decoration-none fa-solid fa-trash mb-2" %>

<%= link_to 'Edit', edit_task_path(@task), class: "mb-" %>

<%= link_to 'Back to list', tasks_path %>
</div>
